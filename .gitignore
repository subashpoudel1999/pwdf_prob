# Local environment secrets — never commit
backend/.env

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Python
__pycache__/
*.pyo

# Claude AI memory (private)
.claude/

# Local WildCat Python packages (not needed for web deployment)
/wildcat/
/wildcat-1.1.0/

# Backend temporary analysis output
backend/data/temp/

# Large local DEM — replaced by GEE download at runtime
assets/data/dolan_dem_3dep10m.tif

# Landsat reflectance rasters — not used by pipeline, too large (25 MB each)
assets/data/dolan_inputs_all/*_L8_refl.tif

# ArcGIS/GDAL auxiliary files — auto-generated, not needed
**/*.aux
**/*.rrd

# Generated runtime cache — recreated automatically on first analysis run
backend/data/dolan_cache/
backend/data/palisades_cache/

# Development notebooks — calibration/debug tools, not production code
notebooks/

# Generated figures
figures/
