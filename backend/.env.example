# Copy this to .env and fill in your local values.
# These only need to be set if running the backend locally with non-default paths.

# Path to your local c_dolan_ml_model directory
ML_DIR=C:\Users\J01040445\Downloads\1. Wildfire folders\c_dolan_ml_model

# Path to the directory containing whitebox_tools.py (dev override only)
# Leave unset when using the pip-installed `whitebox` package
WBT_DIR=C:\Users\J01040445\Downloads\1. Wildfire folders\WBT

# Working directory WhiteboxTools writes intermediate rasters to
WBT_WORK_DIR=C:\wbt_dolan

# Path to whitebox_tools.exe (used by gee_feature_extraction_service)
WBT_EXE=C:\Users\J01040445\Downloads\1. Wildfire folders\WBT\whitebox_tools.exe
